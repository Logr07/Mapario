POSTGRES_DB=lokality_prod
POSTGRES_USER=lokality_app
POSTGRES_PASSWORD=replace-with-strong-database-password

DATABASE_URL=postgresql://lokality_app:replace-with-strong-database-password@db:5432/lokality_prod
FLASK_SECRET_KEY=replace-with-strong-flask-secret
FLASK_ENV=production
FLASK_DEBUG=0
SESSION_COOKIE_SECURE=true
SECURITY_HEADERS_ENABLED=true
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
UPLOAD_FOLDER=/app/uploads
MAX_CONTENT_LENGTH=10485760
PHOTON_BASE_URL=https://photon.komoot.io
PHOTON_USER_AGENT=mapa-bakalarka/1.0 (https://bakalarka.infinitya.eu)
PHOTON_TIMEOUT_SECONDS=8

VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:5000
# Optional comma-separated hostnames for Vite dev server.
# Leave empty to allow Cloudflare Tunnel hostnames during development.
VITE_ALLOWED_HOSTS=
